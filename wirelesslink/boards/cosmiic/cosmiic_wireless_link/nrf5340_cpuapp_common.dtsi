#include "nrf5340_cpuapp_common_pinctrl.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	chosen {
		zephyr,console = &cdc_acm_uart0;
		nordic,nus-uart = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
		zephyr,uart-mcumgr = &uart0;
		zephyr,bt-mon-uart = &uart0;
		zephyr,bt-c2h-uart = &uart0;
		zephyr,bt-hci = &bt_hci_ipc0;
		nordic,802154-spinel-ipc = &ipc0;
		zephyr,ieee802154 = &ieee802154;
	};

	
	//gpios = <&gpio1 4 GPIO_ACTIVE_HIGH>;

	leds {
		compatible = "gpio-leds";

		led0: led_0{
            gpios = <&gpio1 14 (GPIO_ACTIVE_HIGH)>;
            label = "Red LED";
        };

        led1: led_1{
            gpios = <&gpio1 7 (GPIO_ACTIVE_HIGH)>;
            label = "Green LED";
        };

        led2: led_2{
            gpios = <&gpio0 22 (GPIO_ACTIVE_HIGH)>;
            label = "Blue LED";
        };

		en3v3: en3v3{
			gpios = <&gpio1 0 (GPIO_ACTIVE_HIGH)>;
			label = "3V3 enable";
		};
	};

	pwmleds {
		compatible = "pwm-leds";

		pwm_led0: pwm_led_0 {
			pwms = <&pwm0 0 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
			status = "okay";
		};
		
		pwm_led1: pwm_led_1 {
            pwms = <&pwm1 0 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
            status = "okay";
        };
	};

	buttons {
		compatible = "gpio-keys";

		button0: button_0 {
			gpios = <&gpio1 1 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Push button 1";
			zephyr,code = <INPUT_KEY_0>;
		};

		button1: button_1 {
			gpios = <&gpio1 13 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Push button 2";
			zephyr,code = <INPUT_KEY_1>;
		};
	};

	

	// gpio_fwd: nrf-gpio-forwarder {
	// 	compatible = "nordic,nrf-gpio-forwarder";
	// 	status = "disabled";

	// };

	/* These aliases are provided for compatibility with samples */
	aliases {
		led0 = &led0;
		led1 = &led1;
		led2 = &led2;
		en3v3 = &en3v3;
		pwm-led0 = &pwm_led0;
		pwm-led1 = &pwm_led1;
		sw0 = &button0;
		sw1 = &button1;
		bootloader-led0 = &led0;
		mcuboot-button0 = &button0;
		mcuboot-led0 = &led0;
		watchdog0 = &wdt0;
	};

	nrf_radio_coex: coex {
		status = "okay";
		compatible = "nordic,nrf7002-coex";
		req-gpios = <&gpio0 28 GPIO_ACTIVE_HIGH>;
		status0-gpios = <&gpio0 30 GPIO_ACTIVE_HIGH>;
		grant-gpios = <&gpio0 24 (GPIO_PULL_DOWN | GPIO_ACTIVE_LOW)>;
		swctrl1-gpios = <&gpio0 29 GPIO_ACTIVE_HIGH>;
	};
};

&vregmain {
	regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
};

&vregradio {
	regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
};

&vregh {
	status = "okay";
};

&lfxo {
	load-capacitors = "internal";
	load-capacitance-picofarad = <7>;
};

/ {
	zephyr,user {
		io-channels = <&adc 0>; //what does this do?
	};
};

&adc {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";
	channel@0 {
		reg = <0>;
		zephyr,gain = "ADC_GAIN_1_3";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,input-positive = <NRF_SAADC_AIN6>; /*  P0.27 for nRF5340 */
		zephyr,resolution = <12>;
	};
};

&nfct {
	status = "disabled";
};

&gpiote {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&i2c1 {
	status = "disabled";
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-1 = <&uart0_sleep>;
	pinctrl-names = "default", "sleep";
};

&uart3{
    compatible = "nordic,nrf-uarte";
	status = "okay";
    current-speed = <115200>;
    pinctrl-0 = <&uart3_default>;
	pinctrl-1 = <&uart3_sleep>;
    pinctrl-names = "default", "sleep";
};

&pwm0 {
	status = "okay";
	pinctrl-0 = <&pwm0_default>;
	pinctrl-1 = <&pwm0_sleep>;
	pinctrl-names = "default", "sleep";
};

&pwm1 {
    status = "okay";
    pinctrl-0 = <&pwm1_default>;
    pinctrl-1 = <&pwm1_sleep>;
    pinctrl-names = "default", "sleep";
};

&spi1 {
	status = "okay";
	compatible = "nordic,nrf-spim";
	cs-gpios = <&gpio0 20 GPIO_ACTIVE_LOW>;
	pinctrl-0 = <&spi1_default>;
	pinctrl-1 = <&spi1_sleep>;
	pinctrl-names = "default", "sleep";
	medradio: medradio@0 {
		compatible = "vnd,spi-device";
		reg = <0>;
		spi-max-frequency = <4000000>;
		label = "medradio";
	};
	
};


&spi4 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    cs-gpios = <&gpio0 11 GPIO_ACTIVE_LOW>;
    pinctrl-0 = <&spi4_default>;
	pinctrl-1 = <&spi4_sleep>;
	pinctrl-names = "default", "sleep";

    sdhc0: sdhc@0 {
            compatible = "zephyr,sdhc-spi-slot";
            reg = <0>;
            status = "okay";
            sdmmc {  /*changed mmc to sdmmc */
                compatible = "zephyr,sdmmc-disk";
                status = "okay";
				disk-name = "SD";
            };
            spi-max-frequency = <24000000>;
    };
   
};

&i2c2{
	status = "okay";
	//compatible = "nordic,nrf-twim";
	pinctrl-0 = <&i2c2_default>;
	pinctrl-1 = <&i2c2_sleep>;
	pinctrl-names = "default", "sleep";
    clock-frequency = <100000>;  //NHD-Display only supports 50KHz
    ism330is@6A{
        status = "okay";
         compatible = "i2c-device"; //generic, no driver used
        reg=<0x6A>;
        //irq-gpios=<&gpio1 12 GPIO_ACTIVE_HIGH>,<&gpio1 13 GPIO_ACTIVE_HIGH>;
    };
    //The following are only used for the WL within the charger:
    lcddisplay:lcddisplay@3c{
        status="okay";
        compatible = "i2c-device"; //generic, no driver used
        reg = <0x3c>;
        label = "LCDDisplay-NHD-0420";
    };
    ertc:ertc@68{
        status="okay";
        compatible = "i2c-device"; //generic, no driver used
        reg = <0x68>;
        label = "RTC-DS3231";
    };
    dcdc:dcdc@74{
        status="okay";
        compatible = "i2c-device"; //generic, no driver used
        reg = <0x74>;
        label = "DCDC-TPS55289";
    };
    adctherm:adctherm@48{
        status="okay";
        compatible = "i2c-device"; //generic, no driver used
        reg = <0x48>;
        label = "ADC-Thermistor-ADS1110";
    };
    syspower:syspower@41{
        status="okay";
        compatible = "i2c-device"; //generic, no driver used
        reg = <0x41>;
        label = "SysPowerSupplyMonitor-INA236A";
    };
    cdpower:cdpower@40{
        status="okay";
        compatible = "i2c-device"; //generic, no driver used
        reg = <0x40>;
        label = "CDPowerSupplyMonitor-INA236A";
    };

};

&qspi {
	status = "disabled";
	pinctrl-0 = <&qspi_default>;
	pinctrl-1 = <&qspi_sleep>;
	pinctrl-names = "default", "sleep";
};


&spi0{
    status = "disabled";
};

&spi2{
    status = "disabled";
};

&spi3 {
	status = "disabled";
};

&ieee802154 {
	status = "okay";
};

zephyr_udc0: &usbd {
	cdc_acm_uart0: cdc_acm_uart0 {
 		compatible = "zephyr,cdc-acm-uart";
 	};
	status = "okay";
};

/* use NFC pins as regular GPIO */
&uicr {
	nfct-pins-as-gpios;
};

/* Include default memory partition configuration file */
#include <nordic/nrf5340_cpuapp_partition.dtsi>
